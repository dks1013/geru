setImmediate(function(){
Java.perform(function(){

    var logContentArray = new Array();
    
    function uniqBy(array, key) {
        var seen = {};
        return array.filter(function(item) {
            var k = key(item);
            return seen.hasOwnProperty(k) ? false : (seen[k] = true);
        });
    }

    // 대상 클래스의 메소드들을 안전하게 트레이싱하는 함수
    function traceClass(targetClass) {
        try {
            var hook = Java.use(targetClass);
            var methods = hook.class.getDeclaredMethods();
            hook.$dispose;

            var parsedMethods = [];
            methods.forEach(function(method) {
                parsedMethods.push(method.toString().replace(targetClass + ".", "TOKEN").match(/\sTOKEN(.*)\(/)[1]);
            });

            var targets = uniqBy(parsedMethods, JSON.stringify);
            targets.forEach(function(targetMethod) {
                traceMethod(targetClass + "." + targetMethod);
            });
            console.log("[★] Successfully hooked all methods in " + targetClass);
            return true;
        } catch (e) {
            // 클래스가 아직 없으면 조용히 false 리턴
            return false;
        }
    }

    function traceMethod(targetClassMethod) {
        try {
            var delim = targetClassMethod.lastIndexOf(".");
            if (delim === -1) return;

            var targetClass = targetClassMethod.slice(0, delim);
            var targetMethod = targetClassMethod.slice(delim + 1, targetClassMethod.length);
            var hook = Java.use(targetClass);
            var overloadCount = hook[targetMethod].overloads.length;
            
            for (var i = 0; i < overloadCount; i++) {
                // 이미 후킹된 메소드인지 체크하여 중복 후킹 방지 (Fatal 에러 원인 차단)
                if (hook[targetMethod].overloads[i].hasOwnProperty('holder')) continue;

                hook[targetMethod].overloads[i].implementation = function() {
                    var logContent_1 = "entered--" + targetClassMethod;
                    var prefixStr = gainLogPrefix(logContentArray);
                    logContentArray.push(prefixStr + logContent_1);
                    console.log(prefixStr + logContent_1);

                    for (var j = 0; j < arguments.length; j++) {
                        console.log(prefixStr + "arg[" + j + "]: " + arguments[j]);
                    }

                    var retval = this[targetMethod].apply(this, arguments);
                    console.log(prefixStr + "retval: " + retval);
                    console.log(prefixStr + "exiting--" + targetClassMethod);
                    return retval;
                };
            }
        } catch(err) {
            // 생성자나 일부 특수 메소드 후킹 실패 시 fatal 에러 방지
        }
    }

    function gainLogPrefix(theArray) {
        var lastIndex = theArray.length - 1;
        for (var i = lastIndex; i >= 0; i--) {
            var tmpLogContent = theArray[i];
            var cIndex = tmpLogContent.indexOf("entered--");
            if (cIndex == -1) {
                var cIndex2 = tmpLogContent.indexOf("exiting--");
                if (cIndex2 == -1) {
                    continue;
                } else {
                    return tmpLogContent.slice(0, cIndex2);
                }
            } else {
                return tmpLogContent.slice(0, cIndex);
            }
        }
        return "";
    }

    // 무한 루프 없이 안전하게 액티비티 생성을 감지하는 로직
    function safeHookDynamicClass(targetClassName) {
        // 1. 이미 로드되어 있다면 즉시 후킹
        if (traceClass(targetClassName)) return;

        console.log("[*] Target not found yet. Monitoring Activity Lifecycle...");
        var isHooked = false;

        // 2. 안드로이드 자체 내장 액티비티 생명주기 콜백을 이용 (가장 안전함)
        var ActivityThread = Java.use("android.app.ActivityThread");
        var Activity = Java.use("android.app.Activity");

        Activity.onResume.implementation = function() {
            this.onResume();
            var currentActivityName = this.getClass().getName();

            // 대상 액티비티가 켜지는 순간을 포착
            if (currentActivityName === targetClassName && !isHooked) {
                console.log("[+] Target Activity detected on resume: " + currentActivityName);
                isHooked = traceClass(targetClassName);
            }
        };

        // 3. 주기적으로 메모리를 탐색하여 클래스가 올라왔는지 체크 (보조 장치)
        var intervalId = setInterval(function() {
            if (isHooked) {
                clearInterval(intervalId);
                return;
            }
            Java.perform(function() {
                // Java.choose를 통해 메모리에 해당 액티비티 인스턴스가 생성되었는지 확인
                Java.choose(targetClassName, {
                    onMatch: function(instance) {
                        console.log("[+] Target Activity instance found in memory!");
                        isHooked = traceClass(targetClassName);
                        clearInterval(intervalId);
                    },
                    onComplete: function() {}
                });
            });
        }, 1000); // 1초마다 메모리 스캔
    }

    // 실행구문
    setTimeout(function() {
        Java.perform(function() {
            var targetActivity = "com.example.app.TemporaryActivity"; // <--- 여기에 액티비티 경로 입력
            
            console.log("[*] Safe Searching & Waiting for: " + targetActivity);
            safeHookDynamicClass(targetActivity);
        });
    }, 0);

});
});
