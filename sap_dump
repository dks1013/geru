/*
 * SAP GUI 7.50 TypeError 수정 버전
 * 주소 발견 -> 감시 장치 부착 -> 접근 시 DLL/Offset 계산
 */

const targetPass = "YourPassword123!"; // 분석할 비밀번호 입력

function getPattern(str) {
    // UTF-16LE 패턴 생성
    return str.split('').map(c => c.charCodeAt(0).toString(16).padStart(2, '0') + " 00").join(' ');
}

const pattern = getPattern(targetPass);
console.log("[*] 스캔 시작... 패턴: " + pattern);

// 메모리 스캔 및 모니터링 자동화
setInterval(() => {
    Process.enumerateRanges('rw-').forEach(function (range) {
        Memory.scan(range.base, range.size, pattern, {
            onMatch: function (address, size) {
                console.log(`\n[!] 비번 발견! 주소: ${address}`);
                
                // 해당 주소를 읽는 놈을 잡기 위해 모니터 활성화
                MemoryAccessMonitor.enable([{ base: address, size: size }], {
                    onAccess: function (details) {
                        console.log(`\n[!] 데이터 접근 감지! (From: ${details.from})`);
                        
                        // 호출한 지점의 모듈 정보 계산
                        const module = Process.findModuleByAddress(details.from);
                        if (module) {
                            const offset = details.from.sub(module.base);
                            console.log(`[★] 범인 검거: ${module.name} + ${offset}`);
                        }

                        // Backtrace 출력 (context는 details.context 사용)
                        console.log("    [Backtrace]");
                        Thread.backtrace(details.context, Backtrace.ACCURATE)
                              .map(DebugSymbol.fromAddress)
                              .forEach(line => console.log("    " + line));
                        
                        // 한 번 잡으면 부하 방지를 위해 일시 정지
                        MemoryAccessMonitor.disable();
                    }
                });
            },
            onComplete: function () {}
        });
    });
}, 2000);
