Java.perform(function () {
  function stack() {
    var Log = Java.use('android.util.Log');
    var Exception = Java.use('java.lang.Exception');
    return Log.getStackTraceString(Exception.$new());
  }

  var Toast = Java.use('android.widget.Toast');

  // makeText(Context, CharSequence, int)
  Toast.makeText.overload('android.content.Context', 'java.lang.CharSequence', 'int')
    .implementation = function (ctx, text, duration) {
      console.log('[+] Toast.makeText(CharSequence): ' + text + '  duration=' + duration);
      console.log(stack());
      return this.makeText(ctx, text, duration);
    };

  // makeText(Context, int, int)  <-- R.string.slog5 같은 리소스ID
  Toast.makeText.overload('android.content.Context', 'int', 'int')
    .implementation = function (ctx, resId, duration) {
      console.log('[+] Toast.makeText(resId): ' + resId + '  duration=' + duration);
      console.log(stack());
      return this.makeText(ctx, resId, duration);
    };
});