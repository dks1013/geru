// frida_send_overwrite.js

const sendAddr = Module.findExportByName("ws2_32.dll", "send");

if (sendAddr) {
    Interceptor.attach(sendAddr, {
        onEnter: function (args) {
            this.buf = args[1];
            this.len = args[2].toInt32();

            if (this.len > 4) {
                try {
                    // 1. 기존 Big-Endian 길이 헤더 읽기
                    const lenHeader = this.buf.readByteArray(4);
                    const view = new DataView(lenHeader);
                    const jsonLength = view.getUint32(0, false);

                    if (jsonLength > 0 && jsonLength <= this.len - 4) {
                        const jsonBytes = this.buf.add(4).readByteArray(jsonLength);
                        const uint8Array = new Uint8Array(jsonBytes);
                        
                        let jsonStr = "";
                        for (let i = 0; i < uint8Array.length; i++) {
                            jsonStr += String.fromCharCode(uint8Array[i]);
                        }

                        // 2. T_REQUEST 패킷 타깃팅
                        if (jsonStr.trim().startsWith("{") && jsonStr.includes('"type"') && jsonStr.includes('"request"')) {
                            let payload = JSON.parse(jsonStr);
                            
                            console.log("\n[+] [송신 가로채기 성공] 원본 데이터 확인 완료.");

                            // 이름 필드를 '홍길동'으로 조작
                            payload["name"] = "홍길동";

                            const newJsonStr = JSON.stringify(payload);
                            
                            // 프리다 내장 함수를 사용하여 안전하게 UTF-8 바이트 배열로 추출
                            const tmpStringAlloc = Memory.allocUtf8String(newJsonStr);
                            const newLength = Blob.proxy(newJsonStr).size;
                            const newJsonBytes = tmpStringAlloc.readByteArray(newLength);

                            // 3. 새 길이 헤더 구성 (Big Endian)
                            const newHeader = new Uint8Array(4);
                            const newHeaderView = new DataView(newHeader.buffer);
                            newHeaderView.setUint32(0, newLength, false);

                            // 4. [핵심 변경] 원래 주소(args[1])의 메모리 공간에 직접 써서 덮어버림
                            // 기존 공간의 크기가 새 패킷을 담기에 충분한지 검증
                            if (4 + newLength <= this.len) {
                                // 크기가 같거나 작아진 경우 기존 공간에 덮어쓰기
                                this.buf.writeByteArray(newHeader.buffer);
                                this.buf.add(4).writeByteArray(newJsonBytes);
                                args[2] = ptr(4 + newLength); // 보낼 바이트 수 크기 조절
                            } else {
                                // 한글 이름 주입으로 패킷이 원래 버퍼보다 커진 경우:
                                // 안전하게 프로세스 메모리 권한을 변경(Read/Write/Execute)한 후 강제로 밀어 넣습니다.
                                Memory.protect(this.buf, 4 + newLength, 'rwx');
                                this.buf.writeByteArray(newHeader.buffer);
                                this.buf.add(4).writeByteArray(newJsonBytes);
                                args[2] = ptr(4 + newLength);
                            }

                            console.log("[*] [메모리 오버라이트 완수] '홍길동' 주입 완료.");
                            console.log("-> 전송되는 최종 조작 패킷: " + newJsonStr);
                        }
                    }
                } catch (e) {
                    // 계산 예외 발생 시 원본대로 흘러가도록 안전 처리
                }
            }
        }
    });
    console.log("[*] ws2_32.dll!send 후킹 루프 가동 중... 전송 버튼을 누르세요.");
}
