/*
 * SAP GUI 7.50 Credential Trace Script
 * Target Process: saplogon.exe
 */

const targetPassword = "YourPassword123!"; // 테스트 시 입력할 비밀번호로 수정하세요.

function hexEncode(str) {
    // UTF-16LE 대응 (SAP 표준)
    return str.split('').map(c => c.charCodeAt(0).toString(16).padStart(2, '0') + " 00").join(' ');
}

const pattern = hexEncode(targetPassword);
console.log("[*] 감시 시작 - 타겟 패턴:", pattern);

// 1. 실시간 메모리 스캔 루프 (비번이 메모리에 올라오는 순간 포착)
const scanInterval = setInterval(() => {
    Process.enumerateRanges('rw-').forEach(function (range) {
        Memory.scan(range.base, range.size, pattern, {
            onMatch: function (address, size) {
                console.log("\n[!] Credential 발견! 주소:", address);
                
                // 발견된 주소를 누가 읽거나 쓰는지 실시간 감시 (Hardware BP 역할)
                MemoryAccessMonitor.enable([{
                    base: address,
                    size: size
                }], {
                    onAccess: function (details) {
                        console.log(`\n[!] 데이터 접근 감지!`);
                        console.log(`    연산: ${details.operation} | 위치: ${details.from}`);
                        
                        // 접근한 시점의 모듈 정보 확인
                        const module = Process.findModuleByAddress(details.from);
                        if (module) {
                            console.log(`    모듈: ${module.name} (Offset: ${details.from.sub(module.base)})`);
                        }

                        // Call Stack 출력 (x32dbg에서 확인할 지점)
                        console.log("    [Backtrace]\n" + 
                            Thread.backtrace(details.context, Backtrace.ACCURATE)
                            .map(DebugSymbol.fromAddress).join("\n"));
                        
                        // 감시 종료 (한 번 잡으면 부하 방지를 위해 멈춤)
                        MemoryAccessMonitor.disable();
                        clearInterval(scanInterval);
                    }
                });
            },
            onComplete: function () {}
        });
    });
}, 1000);

