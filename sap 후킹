// sapcrypto.dll이 로드되었는지 확인 후 후킹
const moduleName = "sapcrypto.dll";
const sapCrypto = Process.findModuleByName(moduleName);

if (sapCrypto) {
    console.log("[+] " + moduleName + " 기반 주소:", sapCrypto.base);
    
    // 자격 증명 관련 유력 함수들 (심볼이 있을 경우)
    const targets = [
        "SncGetCredentials",
        "SncDecodeToken",
        "SncSetAuthToken"
    ];

    targets.forEach(sym => {
        const addr = Module.findExportByName(moduleName, sym);
        if (addr) {
            Interceptor.attach(addr, {
                onEnter: function (args) {
                    console.log("[*] 후킹 성공: " + sym);
                    // 인자값 분석 (x64이므로 RCX, RDX 순서)
                    console.log(hexdump(args[0], { length: 32 })); 
                }
            });
        }
    });
}


