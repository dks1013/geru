const readlinkPtr = Module.findExportByName("libc.so", "readlink");
if (readlinkPtr) {
    Interceptor.attach(readlinkPtr, {
        onEnter: function (args) {
            this.path = args[0].readUtf8String();
            this.buf = args[1];
        },
        onLeave: function (retval) {
            const len = retval.toInt32();
            if (len > 0) {
                const content = this.buf.readUtf8String(len);
                if (content.includes("frida") || content.includes("memfd")) {
                    console.log("[!] memfd 탐지 우회 시도: " + content);
                    const fake = "/system/lib64/libc.so"; // 아주 정상적인 경로로 위장
                    this.buf.writeUtf8String(fake);
                    retval.replace(fake.length);
                }
            }
        }
    });
}
