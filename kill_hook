const libBase = Module.findBaseAddress("libdyzzwwc.so");

if (libBase) {
    const targetAddr = libBase.add(0x190288); // 백트레이스에서 잡힌 주소
    
    console.log("[!] 탐지 지점 후킹 시작: " + targetAddr);

    Interceptor.attach(targetAddr, {
        onEnter: function (args) {
            console.log("[*] 탐지 로직(190288) 진입! 실행을 차단합니다.");
            
            // 1. 현재 함수의 실행을 중단하고 즉시 리턴시킴 (가장 강력함)
            // 리턴 값은 보통 0(성공)이나 1로 조작해봅니다.
            this.context.pc = this.returnAddress; 
            
            // 만약 위 코드가 불안정하다면 아래처럼 아키텍처에 맞춰 레지스터 조작
            // ARM64 기준 (X0에 0을 넣고 리턴)
            // this.context.x0 = 0;
        }
    });
}
