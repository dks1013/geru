// 전역 공간에 fd를 저장할 맵 생성
var fdMap = {};

// 1. openat 후킹: /proc/.../comm 파일을 여는 순간을 포착
const openatPtr = Module.findExportByName("libc.so", "openat");
Interceptor.attach(openatPtr, {
    onEnter: function (args) {
        // args[1]은 파일 경로
        this.path = args[1].readUtf8String();
    },
    onLeave: function (retval) {
        const fd = retval.toInt32();
        if (fd > 0 && this.path && this.path.includes("/comm")) {
            // 현재 스레드 ID를 키로 하여 fd 저장
            const tid = Process.getCurrentThreadId();
            fdMap[tid] = fd;
            console.log(`[+] 감시 시작 - Path: ${this.path}, FD: ${fd}, TID: ${tid}`);
        }
    }
});

// 2. read 후킹: 저장된 fd로부터 데이터를 읽을 때 조작
const readPtr = Module.findExportByName("libc.so", "read");
Interceptor.attach(readPtr, {
    onEnter: function (args) {
        this.fd = args[0].toInt32();
        this.buf = args[1];
        this.tid = Process.getCurrentThreadId();
    },
    onLeave: function (retval) {
        // 현재 스레드가 방금 열었던 그 fd를 읽고 있는지 확인
        if (fdMap[this.tid] !== undefined && this.fd === fdMap[this.tid]) {
            const content = this.buf.readUtf8String();
            
            if (content && content.includes("pool-frida")) {
                console.log(`[!] 탐지 우회 성공: ${content.trim()} -> 변조됨`);
                
                // 버퍼 내용을 일반적인 이름(예: 무작위 스레드명)으로 교체
                this.buf.writeUtf8String("toy_thread\n");
                
                // 한 번 수정했으면 맵에서 제거 (메모리 관리 및 중복 처리 방지)
                delete fdMap[this.tid];
            }
        }
    }
});
