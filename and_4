'use strict';

const SO = 'libhwobs.so';

function inSo(addr){
  const m = Process.findModuleByAddress(addr);
  return m && m.name === SO;
}

setImmediate(function(){

  Stalker.follow(Process.getCurrentThreadId(), {
    events: { exec: true },

    onReceive(events){
      const parsed = Stalker.parse(events);

      parsed.forEach(ev=>{
        const pc = ev[0];
        if(inSo(pc)){
          console.log('[EXEC]', pc);
        }
      });
    }
  });

});