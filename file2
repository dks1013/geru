const sendAddr = Module.findExportByName("ws2_32.dll", "send");

if (sendAddr) {
    Interceptor.attach(sendAddr, {
        onEnter: function (args) {
            this.buf = args[1];
            this.len = args[2].toInt32();

            if (this.len > 4) {
                try {
                    // 1. 현재 전송 중인 버퍼의 문자열 추출 시도
                    const rawBytes = this.buf.readByteArray(this.len);
                    const uint8 = new Uint8Array(rawBytes);
                    
                    let dataStr = "";
                    for (let i = 0; i < uint8.length; i++) {
                        // 출력 가능한 아스키 영역 및 한글 깨짐을 감안하여 유니코드로 변환
                        dataStr += String.fromCharCode(uint8[i]);
                    }

                    // 2. 버퍼 내에 '안병휘'를 나타내는 UTF-8 바이트 패턴이 존재하는지 파싱
                    // 안병휘 UTF-8: \xec\x95\x88\xeb\xb3\x91\xed\x9a\x98
                    const targetStr = "\xec\x95\x88\xeb\xb3\x91\xed\x9a\x98";
                    const replaceStr = "\xed\x99\x8d\xea,b8\xb8\xeb\x8f\x99"; // 홍길동

                    if (dataStr.includes('request') && (dataStr.includes('안병휘') || dataStr.includes(targetStr))) {
                        console.log("\n[+] [발신 통제] 변조 대상 패킷을 완전히 포착했습니다.");

                        // 3. 실제 제어문 영역(JSON 시작점 '{' 이후)을 추출하여 오브젝트화
                        const jsonStart = dataStr.indexOf('{');
                        if (jsonStart !== -1) {
                            const validJsonPart = dataStr.substring(jsonStart);
                            let payload = JSON.parse(validJsonPart);

                            // 강력하게 이름을 강제 치환
                            payload["name"] = "홍길동";

                            // 4. 조작된 데이터로 JSON 다시 빌드
                            const hackedJsonStr = JSON.stringify(payload);
                            const encoder = new TextEncoder();
                            const hackedJsonBytes = encoder.encode(hackedJsonStr);
                            const newJsonLen = hackedJsonBytes.length;

                            // 5. 프로토콜 양식에 맞춰 [4바이트 BE 길이] + [새 JSON] 형태로 완전히 새로 조립
                            const finalPack = Memory.alloc(4 + newJsonLen);
                            const packView = new DataView(newHeader.buffer);
                            
                            // 길이 헤더 갱신
                            const newHeader = new Uint8Array(4);
                            const headerView = new DataView(newHeader.buffer);
                            headerView.setUint32(0, newJsonLen, false); // Big Endian

                            finalPack.writeByteArray(newHeader.buffer);
                            finalPack.add(4).writeByteArray(hackedJsonBytes);

                            // 6. 소켓 API 인자 값을 신규 패킷 정보로 전면 교체
                            args[1] = finalPack;
                            args[2] = ptr(4 + newJsonLen);

                            console.log("[*] [성공] 패킷 길이 및 인코딩 데이터를 '홍길동' 기준으로 완벽히 재구축하여 전송했습니다.");
                            console.log("-> 보낸 데이터: " + hackedJsonStr);
                        }
                    }
                } catch (err) {
                    // 데이터 파싱 예외 발생 시 전송 흐름을 끊지 않기 위해 통과
                }
            }
        }
    });
    console.log("[*] 완벽한 무결성 재계산 후킹 엔진 가동 중...");
}
