'use strict';

const SO = 'libhwobs.so';

function toPtr(x) {
  try { return ptr(x); } catch (e) { return new NativePointer(x); }
}

function inSo(pc){
  const m = Process.findModuleByAddress(pc);
  return m && m.name === SO;
}

setImmediate(function () {
  Stalker.follow(Process.getCurrentThreadId(), {
    events: { exec: true },
    onReceive(events) {
      const parsed = Stalker.parse(events);
      for (let i = 0; i < parsed.length; i++) {
        const pc = toPtr(parsed[i][0]);   // ✅ 포인터로 변환
        if (inSo(pc)) console.log('[EXEC]', pc);
      }
    }
  });
});