Java.perform(function () {
  var methodName = "여기에_후킹하고싶은_메서드명"; // 예: checkRoot, verify, a, b 등
  var onlyAppPrefix = null; // 예: "com.target.app" 넣으면 속도/노이즈 개선됨. 모르면 null 유지.

  console.log("[*] Searching loaded classes that have method:", methodName);

  Java.enumerateLoadedClasses({
    onMatch: function (name) {
      try {
        if (onlyAppPrefix && !name.startsWith(onlyAppPrefix)) return;

        var K = Java.use(name);
        var methods = K.class.getDeclaredMethods(); // java.lang.reflect.Method[]
        for (var i = 0; i < methods.length; i++) {
          var m = methods[i].getName().toString();
          if (m === methodName) {
            console.log("[+] Found " + name + "." + methodName);
            // 오버로드/시그니처도 같이 보고 싶으면:
            console.log("    " + methods[i].toString());
          }
        }
        K.$dispose();
      } catch (e) {
        // 일부 시스템/프록시 클래스는 접근 실패 가능. 무시.
      }
    },
    onComplete: function () {
      console.log("[*] Done.");
    }
  });
});